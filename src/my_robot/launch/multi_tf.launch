<launch>

    <!-- world -> son1 -->
    <node pkg="tf2_ros"
          type="static_transform_publisher"
          name="son1"
          args="1 0 0 0 0 0 world son1" />

    <!-- world -> son2 -->
    <node pkg="tf2_ros"
          type="static_transform_publisher"
          name="son2"
          args="0 1 0 0 0 0 world son2" />

</launch>